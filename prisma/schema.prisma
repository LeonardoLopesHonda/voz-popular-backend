// Voz Popular — Prisma Schema
// Stack: NestJS + Prisma + PostgreSQL (Supabase)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum OccurrenceStatus {
  RECEIVED
  UNDER_REVIEW
  IN_PROGRESS
  COMPLETED
  REJECTED
  SUSPENDED
}

enum Provider {
  LOCAL    @map("local")
  GOOGLE   @map("google")
  FACEBOOK @map("facebook")
}

// ─────────────────────────────────────────────
// Sectors
// ─────────────────────────────────────────────

model Sector {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users User[]

  @@map("sectors")
}

// ─────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────

model User {
  id              Int       @id @default(autoincrement())
  sectorId        Int?      @map("sector_id")
  name            String
  email           String    @unique
  password        String?
  bio             String?
  isAdmin         Boolean   @default(false) @map("is_admin")
  provider        Provider? @default(LOCAL)
  providerId      Int?      @map("provider_id")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  sector      Sector?      @relation(fields: [sectorId], references: [id])
  occurrences Occurrence[]
  comments    Comment[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Categories
// ─────────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  occurrences Occurrence[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// Themes
// ─────────────────────────────────────────────

model Theme {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  occurrences Occurrence[]

  @@map("themes")
}

// ─────────────────────────────────────────────
// Occurrences
// ─────────────────────────────────────────────

model Occurrence {
  id              Int              @id @default(autoincrement())
  userId          Int              @map("user_id")
  categoryId      Int              @map("category_id")
  themeId         Int              @map("theme_id")
  title           String
  description     String
  street          String
  number          String?
  neighborhood    String
  reference       String?
  latitude        Float
  longitude       Float
  status          OccurrenceStatus @default(RECEIVED)
  imageUrl        String?          @map("image_url")
  rejectionReason String?          @map("rejection_reason")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  category Category  @relation(fields: [categoryId], references: [id])
  theme    Theme     @relation(fields: [themeId], references: [id])
  comments Comment[]
  updates  Update[]

  @@map("occurrences")
}

// ─────────────────────────────────────────────
// Comments
// ─────────────────────────────────────────────

model Comment {
  id           Int      @id @default(autoincrement())
  occurrenceId Int      @map("occurrence_id")
  userId       Int      @map("user_id")
  content      String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)
  user       User       @relation(fields: [userId], references: [id])

  @@map("comments")
}

// ─────────────────────────────────────────────
// Updates (Admin workflow history)
// ─────────────────────────────────────────────

model Update {
  id                  Int              @id @default(autoincrement())
  occurrenceId        Int              @map("occurrence_id")
  message             String
  status              OccurrenceStatus
  estimatedCompletion DateTime?        @map("estimated_completion")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  occurrence Occurrence @relation(fields: [occurrenceId], references: [id], onDelete: Restrict)

  @@map("updates")
}
